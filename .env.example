# Pi SDK provider API keys
GROQ_API_KEY=
ZAI_API_KEY=
OPENROUTER_API_KEY=

# Optional default routing
# PI_DEFAULT_PROVIDER=openrouter
# PI_DEFAULT_MODEL=openai/gpt-5

# MCP gateway tool (enabled by default)
# PI_ENABLE_MCP_TOOL=true

# Optional MCP config override (defaults to ./.pi/mcp.json or ~/.pi/agent/mcp.json)
# PI_MCP_CONFIG=/absolute/path/to/mcp.json

# Optional global MCP idle timeout when not specified in config
# PI_MCP_IDLE_TIMEOUT_MINUTES=10

# Example bearer token env var used by docs/mcp.example.json
CONTEXT7_API_KEY=
