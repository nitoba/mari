# Pi SDK provider API keys
GROQ_API_KEY=
ZAI_API_KEY=
OPENROUTER_API_KEY=

# Optional default routing
# PI_DEFAULT_PROVIDER=openrouter
# PI_DEFAULT_MODEL=openai/gpt-5

# MCP gateway tool (enabled by default)
# PI_ENABLE_MCP_TOOL=true
# PI_ENABLE_AGROTRACE_TOOLS=true
# PI_ENABLE_SKILLS=true

# Optional extra skill directories (comma or colon separated)
# PI_SKILL_PATHS=/var/home/nitoba/.config/opencode/skills,/var/home/nitoba/.claude/skills

# Optional allowlist of skill names
# PI_SKILL_ALLOWLIST=pdf,data-spreadsheet,chart-visualization,infographic-creator

# Optional MCP config override (defaults to ./.pi/mcp.json or ~/.pi/agent/mcp.json)
# PI_MCP_CONFIG=/absolute/path/to/mcp.json

# Optional global MCP idle timeout when not specified in config
# PI_MCP_IDLE_TIMEOUT_MINUTES=10

# Optional database name hint used by Agrotrace MCP tools when listing tables
# AGROTRACE_DATABASE=agrotrace

# Example bearer token env var used by docs/mcp.example.json
CONTEXT7_API_KEY=
